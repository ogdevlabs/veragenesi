# Database Configuration
# NOTE: On macOS with Homebrew PostgreSQL the default superuser is your macOS
# username, NOT 'postgres'. Either set DB_USER to your username, or create the
# role first: psql postgres -c "CREATE ROLE postgres SUPERUSER LOGIN PASSWORD 'password';"
# When using Docker (docker-compose up -d) the 'postgres' user is created automatically.
DB_USER=postgres
DB_PASSWORD=password
# Use 127.0.0.1 instead of 'localhost' — on macOS, 'localhost' resolves to ::1 (IPv6)
# which Docker Desktop does not forward correctly through its VM layer.
DB_HOST=127.0.0.1
# Port 5433 is used to avoid conflict with a local Homebrew PostgreSQL on 5432
DB_PORT=5432
DB_NAME=vera_genesi_dev

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=24h
